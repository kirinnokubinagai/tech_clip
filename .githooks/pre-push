#!/bin/bash
# pre-push: プッシュ対象のコミットからシークレットを検知

REMOTE="$1"
URL="$2"

while read LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
  if [ "$LOCAL_SHA" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  if [ "$REMOTE_SHA" = "0000000000000000000000000000000000000000" ]; then
    RANGE="$LOCAL_SHA"
  else
    RANGE="${REMOTE_SHA}..${LOCAL_SHA}"
  fi

  DIFF=$(git diff "$RANGE" 2>/dev/null)
  if [ -z "$DIFF" ]; then
    continue
  fi

  PATTERNS=(
    'ANTHROPIC_API_KEY\s*='
    'OPENAI_API_KEY\s*='
    'STRIPE_API_KEY\s*='
    'STRIPE_SECRET_KEY\s*='
    'DATABASE_URL\s*=\s*["\x27]?(postgres|mysql|sqlite)'
    'JWT_SECRET\s*='
    'AWS_SECRET_ACCESS_KEY\s*='
    'TURSO_AUTH_TOKEN\s*='
    'BETTER_AUTH_SECRET\s*='
    'CLOUDFLARE_API_TOKEN\s*='
    'REVENUE_CAT_API_KEY\s*='
    'SENTRY_DSN\s*='
    'sk_live_'
    'sk_test_'
    'sk-[a-zA-Z0-9]{20,}'
    'ghp_[a-zA-Z0-9]{36}'
  )

  for PATTERN in "${PATTERNS[@]}"; do
    MATCH=$(echo "$DIFF" | grep -Ei "^\+" | grep -Ei "$PATTERN" | head -1)
    if [ -n "$MATCH" ]; then
      echo ""
      echo "🚨 シークレット検出 - プッシュをブロックしました"
      echo "================================================"
      echo "  パターン: ${PATTERN}"
      echo "  内容: ${MATCH}"
      echo ""
      echo "対処: git reset でコミットを取り消し、シークレットを除去してください"
      echo ""
      exit 1
    fi
  done
done

exit 0

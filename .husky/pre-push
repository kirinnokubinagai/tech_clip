#!/bin/bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
NIX_BIN="${NIX_BIN:-$(command -v nix 2>/dev/null || true)}"

if [ -z "${NIX_BIN}" ] && [ -x "/nix/var/nix/profiles/default/bin/nix" ]; then
  NIX_BIN="/nix/var/nix/profiles/default/bin/nix"
fi

if [ "${TECH_CLIP_PRE_PUSH_NIX_BOOTSTRAPPED:-0}" != "1" ]; then
  if [ -n "${NIX_BIN}" ]; then
    if [ -z "${IN_NIX_SHELL:-}" ] || ! command -v pnpm > /dev/null 2>&1; then
      exec "${NIX_BIN}" develop "${REPO_ROOT}" --command env TECH_CLIP_PRE_PUSH_NIX_BOOTSTRAPPED=1 bash "${SCRIPT_PATH}" "$@"
    fi
  fi
fi

if ! command -v pnpm > /dev/null 2>&1; then
  echo "Pre-push チェック失敗: pnpm コマンドが見つかりません。"
  exit 1
fi

cd "${REPO_ROOT}"

# Capture push SHAs for config-only detection after the loop.
# PUSH_REMOTE_SHA is set to merge-base with origin/main for new-branch pushes.
PUSH_LOCAL_SHA=""
PUSH_REMOTE_SHA=""

while read -r _LOCAL_REF LOCAL_SHA _REMOTE_REF REMOTE_SHA; do
  if [ "${LOCAL_SHA}" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi
  PUSH_LOCAL_SHA="${LOCAL_SHA}"
  if [ "${REMOTE_SHA}" = "0000000000000000000000000000000000000000" ]; then
    # New branch: use merge-base with origin/main for diff-based change detection.
    PUSH_REMOTE_SHA="$(git merge-base "${LOCAL_SHA}" "origin/main" 2>/dev/null || true)"
    continue
  fi
  PUSH_REMOTE_SHA="${REMOTE_SHA}"
  if ! git merge-base --is-ancestor "${REMOTE_SHA}" "${LOCAL_SHA}"; then
    echo "非 fast-forward push は禁止されています。"
    exit 1
  fi
done

echo "Pre-push チェック実行中..."

echo "  Executable bits..."
"${REPO_ROOT}/scripts/check-executable-shell-files.sh" || {
  echo "Shell script の executable bit が不足しています。修正してからpushしてください。"
  exit 1
}

# Config-only skip: if every changed file is a config/doc path that contains no
# TypeScript/JavaScript, skip lint / typecheck / audit / test.
# Covered paths: .claude/** (skills, rules, agents), docs/**, scripts/skills/**,
# .codex/**, CLAUDE.md, AGENTS.md.
_SKIP_HEAVY_CHECKS=0
if [ -n "${PUSH_LOCAL_SHA:-}" ] && [ -n "${PUSH_REMOTE_SHA:-}" ]; then
  _CHANGED="$(git diff --name-only "${PUSH_REMOTE_SHA}" "${PUSH_LOCAL_SHA}" 2>/dev/null || true)"
  if [ -n "${_CHANGED}" ]; then
    _NON_CONFIG="$(echo "${_CHANGED}" | \
      grep -vE '^(\.claude/|\.husky/|docs/|scripts/skills/|\.codex/)' | \
      grep -vE '^(CLAUDE\.md|AGENTS\.md)$' || true)"
    if [ -z "${_NON_CONFIG}" ]; then
      echo "  設定・ドキュメントのみの変更を検出しました。lint / typecheck / audit / test をスキップします。"
      _SKIP_HEAVY_CHECKS=1
    fi
  fi
fi

if [ "${_SKIP_HEAVY_CHECKS}" = "0" ]; then
  echo "  Lint..."
  pnpm lint || { echo "Lint失敗。修正してからpushしてください。"; exit 1; }

  echo "  Typecheck..."
  pnpm typecheck || { echo "Typecheck失敗。修正してからpushしてください。"; exit 1; }

  echo "  Audit..."
  # --ignore-registry-errors: pnpm@10.33.0 の既知バグ (https://github.com/pnpm/pnpm/issues/11265) への暫定対応
  # npm registry の audit エンドポイント廃止に pnpm がまだ追随していないため、
  # registry エラー時は audit を green 扱いにする。pnpm が新 bulk advisory 対応版を
  # リリースしたらこのフラグは削除すること。
  pnpm audit --prod --ignore-registry-errors || { echo "Audit失敗。脆弱性を解消してからpushしてください。"; exit 1; }

  echo "  Test..."
  "${REPO_ROOT}/scripts/run-and-fail-on-stderr.sh" pnpm test || {
    echo "Test失敗。stderr がある場合は内容確認後に TECH_CLIP_ALLOW_TEST_STDERR=1 を付けて再pushしてください。"
    exit 1
  }
fi

echo "全チェック通過"

# Maestro smoke test
# CI 環境のみスキップ。ローカルでは必ず全件実行する。
if [ "${CI:-}" = "true" ] || [ "${GITHUB_ACTIONS:-}" = "true" ]; then
  echo "[pre-push] CI 環境のため smoke test をスキップ"
  exit 0
fi

# maestro インストール確認
if ! command -v maestro >/dev/null 2>&1; then
  echo "[pre-push] ERROR: maestro がインストールされていません。"
  echo "  インストール: curl -Ls \"https://get.maestro.mobile.dev\" | bash"
  exit 1
fi

# adb / emulator 確認
if ! command -v adb >/dev/null 2>&1; then
  echo "[pre-push] ERROR: adb が見つかりません。Android SDK を確認してください。"
  exit 1
fi
if ! adb devices 2>/dev/null | grep -q "emulator"; then
  echo "[pre-push] ERROR: Android emulator が起動していません。"
  echo "  起動例: emulator -avd <avd-name> &"
  exit 1
fi

# Turso が未起動なら自動起動する
if ! curl -sf -o /dev/null --max-time 3 -X POST \
     -H "Content-Type: application/json" \
     -d '{"requests":[]}' \
     "http://127.0.0.1:8888/v2/pipeline" 2>/dev/null; then
  echo "[pre-push] Turso dev サーバーが未起動です。自動起動します..."
  if ! bash "${REPO_ROOT}/scripts/ci/start-turso.sh"; then
    echo "[pre-push] ERROR: Turso dev サーバーの起動に失敗しました。"
    echo "  手動起動: turso dev --port 8888 --db-file local.db"
    exit 1
  fi
  echo "[pre-push] Turso dev サーバーが起動しました"
fi

echo "[pre-push] e2e 環境をリセット中..."
if ! bash "${REPO_ROOT}/scripts/e2e/reset-e2e-env.sh"; then
  echo "[pre-push] ERROR: e2e 環境リセットに失敗しました。"
  exit 1
fi
echo "[pre-push] e2e 環境リセット完了"

echo "[pre-push] maestro smoke test を実行中..."
# 複数 worktree 並列 push 時のポート衝突回避:
# worktree パスのハッシュから ANDROID_SERIAL を決定する（起動中エミュレーター一覧からインデックス選択）
_WORKTREE_HASH="$(echo "${REPO_ROOT}" | shasum -a 256 | cut -c1-8)"
# bash 3.2 互換の配列構築（macOS デフォルト bash は 3.2 のため mapfile 不可）
_EMULATORS=()
while IFS= read -r _e; do
  _EMULATORS+=("$_e")
done < <(adb devices 2>/dev/null | grep "emulator" | awk '{print $1}')
if (( ${#_EMULATORS[@]} == 0 )); then
  echo "[pre-push] ERROR: emulator リストが空です（adb devices で再確認してください）。"
  exit 1
fi
_IDX=$(( 16#${_WORKTREE_HASH} % ${#_EMULATORS[@]} ))
export ANDROID_SERIAL="${_EMULATORS[${_IDX}]}"

# .env.yaml は環境変数ファイルであり flow ではないため除外する
# maestro がディレクトリを再帰スキャンすると .env.yaml を flow として
# 解釈し "Either 'url' or 'appId' must be specified" で失敗するため
_SMOKE_FLOWS=()
while IFS= read -r _f; do
  _SMOKE_FLOWS+=("$_f")
done < <(find "${REPO_ROOT}/tests/e2e/maestro" -maxdepth 1 -name "*.yaml" ! -name ".env.yaml" ! -name "config.yaml" | sort)
if (( ${#_SMOKE_FLOWS[@]} == 0 )); then
  echo "[pre-push] ERROR: smoke flow が見つかりません。"
  exit 1
fi

# .env.yaml から key=value を読み込み --env 引数に展開する
# (maestro にディレクトリを渡さないため env block が自動ロードされない)
_MAESTRO_ENV_ARGS=()
_ENV_FILE="${REPO_ROOT}/tests/e2e/maestro/.env.yaml"
if [ -f "$_ENV_FILE" ]; then
  while IFS= read -r _line; do
    case "$_line" in
      ''|'#'*) continue ;;
    esac
    _k="${_line%%:*}"
    _v="${_line#*: }"
    [ -z "$_k" ] && continue
    _MAESTRO_ENV_ARGS+=("--env" "${_k}=${_v}")
  done < "$_ENV_FILE"
fi
if ! timeout 900 maestro test \
     "${_MAESTRO_ENV_ARGS[@]}" \
     "${_SMOKE_FLOWS[@]}"; then
  echo ""
  echo "❌ maestro smoke test 失敗"
  echo "修正するか、どうしても push したい場合は git push --no-verify"
  exit 1
fi
echo "✅ maestro smoke test OK"

# Dependencies
node_modules

# Turborepo
.turbo

# Build outputs
dist/
build/
.next/

# TypeScript incremental build cache
*.tsbuildinfo

# Expo
.expo/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/
ios/
android/

# Cloudflare Workers
.wrangler/
.dev.vars

# Environment variables
.env
.env.local
.env.*.local

# Maestro E2E テスト認証情報
tests/e2e/maestro/.env.yaml

# Log files
*.log

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Drizzle
drizzle/meta/

# SQLite local databases
*.db

# Test coverage
coverage/

# Worktrees (兄弟ディレクトリとして作成されるため .gitignore 不要)

# OMC (oh-my-claudecode state)
.omc/

# Claude Code ランタイムロックファイル
.claude/*.lock
# レビュー済みマーカー（reviewer エージェントのみが生成。コミット禁止）
.claude/.review-passed
.claude/.e2e-passed
# ポーリング状態ファイル（CI watcher の一時ファイル）
.claude/polling/

# Claude Code ユーザー設定ディレクトリ（認証情報を含むため除外）
.claude-user/

# Nix
result
result-*

# direnv
.direnv/

# Python
__pycache__/
*.pyc

# Other tools
.grepai/

# OTA code signing keys (never commit — certificate.pem is generated dynamically in CI)
# See apps/mobile/certs/README.md for generation instructions
apps/mobile/certs/*.pem
.serena/

# ZAP scan report (generated by pre-push hook)
.zap/

# AI review results (generated by pre-push hook)
.reviews/

# OMC 分離用の隔離 HOME（Nix シェルが自動生成）
.claude-isolated/

# Brainstorming / design specs (not for PRs)
docs/superpowers/
docs/design/
docs/design-wip/

# reviewer agent CI download temp
.claude/tmp/

# polling state files (runtime, not for PRs)
.claude/polling/

# Maestro screenshot / debug 出力 (run-e2e-parallel.sh が cleanup hook で自動削除)
tests/e2e/maestro/screenshots/
screenshots/
debug-output/
.maestro/
.claude/.e2e-debug-shard*.json

local.db-shm
local.db-wal
.claude/tmp-*
.claude/.e2e-debug.json
.claude/.e2e-progress.json

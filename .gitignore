# Dependencies
node_modules

# Turborepo
.turbo

# Build outputs
dist/
build/
.next/

# TypeScript incremental build cache
*.tsbuildinfo

# Expo
.expo/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/
ios/
android/

# Cloudflare Workers
.wrangler/
.dev.vars

# Environment variables
.env
.env.local
.env.*.local

# Maestro E2E テスト認証情報
tests/e2e/maestro/.env.yaml

# Log files
*.log

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Drizzle
drizzle/meta/

# SQLite local databases
*.db

# Test coverage
coverage/

# Worktrees (兄弟ディレクトリとして作成されるため .gitignore 不要)

# OMC (oh-my-claudecode state)
.omc/

# Claude Code ランタイムロックファイル
.claude/*.lock

# Claude Code ユーザー設定ディレクトリ（認証情報を含むため除外）
.claude-user/

# Nix
result
result-*

# direnv
.direnv/

# Python
__pycache__/
*.pyc

# Other tools
.grepai/

# OTA code signing private key (never commit)
# ワイルドカードで将来追加される秘密鍵ファイルも除外
apps/mobile/certs/*.pem
# 公開鍵証明書はコミット可能なため除外から外す
!apps/mobile/certs/certificate.pem
.serena/

# ZAP scan report (generated by pre-push hook)
.zap/

# AI review results (generated by pre-push hook)
.reviews/

# OMC 分離用の隔離 HOME（Nix シェルが自動生成）
.claude-isolated/

# =============================================================================
# API サーバー 環境変数 (.env)
# =============================================================================
# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env は .gitignore により Git 管理対象外です。絶対にコミットしないこと。
#
# Cloudflare Workers のシークレットは `wrangler secret put <KEY>` で設定します。
# ローカル開発では .dev.vars に同じキーを記述して利用します。
# =============================================================================

# -----------------------------------------------------------------------------
# Turso (libSQL) データベース
# -----------------------------------------------------------------------------
# Turso ダッシュボード (https://app.turso.tech) でDBを作成後に取得する
# ローカル開発: file:local.db（SQLiteファイルを使用）
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# openssl rand -base64 32 などで生成する（32文字以上推奨）
BETTER_AUTH_SECRET=your-better-auth-secret-here

# -----------------------------------------------------------------------------
# trustedOrigins（CORS許可オリジン追加）
# -----------------------------------------------------------------------------
# カンマ区切りで複数指定可能。未設定時はデフォルト値のみ使用される。
# デフォルト: https://techclip.app, https://api.techclip.app, http://localhost:8081, techclip://
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8081

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
# Google Cloud Console (https://console.cloud.google.com) で OAuth クライアントを作成後に取得する
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Apple OAuth
# -----------------------------------------------------------------------------
# Apple Developer Console で Sign in with Apple を設定後に取得する
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# GitHub OAuth
# -----------------------------------------------------------------------------
# GitHub Settings > Developer settings > OAuth Apps で作成後に取得する
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Cloudflare Workers AI (AI推論)
# -----------------------------------------------------------------------------
# Workers AI は wrangler.toml の [ai] バインディングで自動的に設定される。
# 追加の環境変数設定は不要。モデル: @cf/google/gemma-4-26b-a4b-it

# -----------------------------------------------------------------------------
# Resend (メール送信)
# -----------------------------------------------------------------------------
# Resend ダッシュボード (https://resend.com) でAPIキーを取得する
RESEND_API_KEY=
FROM_EMAIL=noreply@techclip.app

# -----------------------------------------------------------------------------
# アプリURL
# -----------------------------------------------------------------------------
# パスワードリセットリンク生成用（省略時はデフォルトURL使用）
APP_URL=http://localhost:8081

# -----------------------------------------------------------------------------
# Sentry (エラー監視)
# -----------------------------------------------------------------------------
# Sentry ダッシュボード (https://sentry.io) でプロジェクトを作成後に取得する（省略可）
SENTRY_DSN=

# -----------------------------------------------------------------------------
# RevenueCat (課金)
# -----------------------------------------------------------------------------
# RevenueCat ダッシュボード (https://app.revenuecat.com) でWebhookシークレットを取得する（省略可）
REVENUECAT_WEBHOOK_SECRET=

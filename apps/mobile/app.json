{
  "expo": {
    "name": "TechClip",
    "slug": "tech-clip",
    "scheme": "techclip",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": ["ios", "android", "web"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.techclip.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.techclip.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    }
  }
}

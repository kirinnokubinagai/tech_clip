# =============================================================================
# Expo モバイルアプリ 環境変数 (.env)
# =============================================================================
# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env は .gitignore により Git 管理対象外です。絶対にコミットしないこと。
#
# EXPO_PUBLIC_ プレフィックスが付いた変数はアプリバンドルに含まれるため、
# 機密情報は設定しないこと。
#
# 取得手順の詳細は docs/SECRETS.md を参照してください。
# =============================================================================

# -----------------------------------------------------------------------------
# API 接続先 URL
# -----------------------------------------------------------------------------
# ローカル開発: http://localhost:8787 (デフォルト、省略可)
# 実機テスト:   http://<PCのIPアドレス>:8787
# Staging:      https://api-staging.techclip.app
# Production:   https://api.techclip.app

EXPO_PUBLIC_API_URL=http://localhost:8787

# -----------------------------------------------------------------------------
# RevenueCat (課金・サブスクリプション管理)
# -----------------------------------------------------------------------------
# RevenueCat ダッシュボード (https://app.revenuecat.com) でプロジェクトを作成後、
# API Keys セクションから Public SDK キーを取得する
# iOS / Android それぞれ別のキーが発行される

EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your-revenuecat-ios-api-key
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=your-revenuecat-android-api-key

# -----------------------------------------------------------------------------
# EAS Submit (ストア提出認証情報)
# -----------------------------------------------------------------------------
# 以下の値は EAS Secrets で管理する。ローカルの .env には設定しない。
# 設定方法: eas secret:create --scope project --name <KEY> --value <VALUE>
# 詳細: https://docs.expo.dev/eas/using-secrets/
#
# iOS (App Store Connect)
# Apple ID (Apple Developer アカウントのメールアドレス)
APPLE_ID=your-apple-id@example.com
# App Store Connect の App ID (数字のみ)
ASC_APP_ID=1234567890
# Apple Developer Team ID (10文字の英数字)
APPLE_TEAM_ID=XXXXXXXXXX
#
# Android (Google Play)
# Google Play サービスアカウントキーの JSON ファイルパス
# EAS ビルド環境では EAS Secrets に JSON 内容を登録し、
# CI/CD パイプラインでファイルに書き出して参照する
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account-key.json

{
  "$schema": "./config.schema.json",
  "claude_review_job_name": "claude-review",
  "ci_workflow_name": "CI",
  "e2e_workflow_name": "PR E2E (Android)",
  "ai_review_pass_label": "AI Review: PASS",
  "ai_review_needs_work_label": "AI Review: NEEDS WORK",
  "required_status_check_context": "CI / ci-gate",
  "verdict_patterns": {
    "approve": [
      "(\\*\\*)?✅ Approve(\\*\\*)?",
      "全件 PASS（0件）"
    ],
    "request_changes": [
      "(\\*\\*)?🔄 Request Changes(\\*\\*)?",
      "(\\*\\*)?💬 Comment(\\*\\*)?"
    ]
  },
  "polling_interval_minutes": 2,
  "polling_timeout_minutes": 60,
  "polling_dir": ".claude/polling",
  "manual_review_triggers": {
    "workflow_file_paths": [
      "^\\.github/workflows/"
    ],
    "stacked_pr_base_excludes": [
      "main"
    ]
  },
  "max_parallel_issues": 3,
  "human_review_labels": [
    "release",
    "requires-human"
  ],
  "human_review_title_patterns": [
    "go-no-go",
    "store",
    "production",
    "smoke test",
    "本番"
  ],
  "conflict_zones": {
    "api-entry": {
      "files": ["apps/api/src/index.ts", "wrangler.toml", "wrangler.jsonc"],
      "keywords": ["cron", "scheduled", "route registration", "wrangler", "cf worker entry"]
    },
    "api-migration": {
      "files": ["apps/api/drizzle/", "apps/api/src/db/schema/", "apps/api/src/db/schema.ts"],
      "keywords": ["migration", "drizzle", "schema", "table", "column", "drizzle-kit"]
    },
    "api-auth": {
      "files": ["apps/api/src/app/auth-subapp.ts", "apps/api/src/routes/auth.ts", "apps/api/src/auth/"],
      "keywords": ["oauth", "login", "session", "token", "password", "better-auth", "auth flow"]
    },
    "api-rate-limit": {
      "files": ["apps/api/src/middleware/rate-limit", "apps/api/src/lib/rate-limit"],
      "keywords": ["rate limit", "rate-limit", "throttle", "kv store"]
    },
    "infra-ci": {
      "files": [".github/workflows/", "scripts/gate/", "scripts/ci/"],
      "keywords": ["ci", "workflow", "gate", "github actions", "ci-gate"]
    },
    "infra-harness": {
      "files": ["CLAUDE.md", ".claude/skills/", ".claude/agents/", ".claude/hooks/"],
      "keywords": ["harness", "orchestrator", "skill definition", "agent definition", "hook"]
    },
    "mobile-screens": {
      "files": ["apps/mobile/app/", "apps/mobile/screens/"],
      "keywords": ["screen", "画面", "navigation"]
    },
    "mobile-shared-ui": {
      "files": ["apps/mobile/components/ui/", "apps/mobile/lib/theme"],
      "keywords": ["shared component", "theme", "tailwind", "nativewind"]
    },
    "design-tokens": {
      "files": ["apps/mobile/tailwind.config", "apps/mobile/lib/colors", "tokens/"],
      "keywords": ["color token", "テーマカラー", "design token"]
    }
  }
}

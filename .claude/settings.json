{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 15,
            "statusMessage": "Syncing with remote..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/secret-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking for secrets..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(drizzle-kit push:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git checkout -- :*)",
      "Bash(git clean:*)",
      "Bash(git branch -D:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(chmod 777:*)",
      "Bash(sudo:*)"
    ]
  }
}

{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 15,
            "statusMessage": "Syncing with remote..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/secret-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking for secrets..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(turbo:*)",
      "Bash(biome:*)",
      "Bash(drizzle-kit:*)",
      "Bash(vitest:*)",
      "Bash(expo:*)",
      "Bash(wrangler:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(find:*)",
      "Bash(sort:*)",
      "Bash(jq:*)",
      "Bash(cd:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(ps:*)",
      "Bash(lsof:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "mcp__pencil",
      "mcp__context7"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(drizzle-kit push:*)"
    ]
  }
}

{
  "schema_version": 1,
  "review_gate": {
    "required_paths": [
      "**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx",
      "**/*.py", "**/*.go", "**/*.rs", "**/*.kt", "**/*.swift",
      "**/*.sh", "**/Dockerfile*",
      ".github/workflows/**", ".claude/**", "CLAUDE.md", "scripts/**",
      "apps/**", "packages/**", "tests/**"
    ],
    "auto_pass_paths": [
      "**/*.md", "docs/**",
      "**/*.png", "**/*.jpg", "**/*.svg", "**/*.ico", "**/*.webp",
      ".gitignore", "**/LICENSE*", "**/CHANGELOG.md"
    ]
  },
  "e2e_gate": {
    "always_required_paths": [
      "apps/mobile/src/components/**",
      "apps/mobile/src/screens/**",
      "apps/mobile/src/hooks/**",
      "apps/mobile/src/lib/**",
      "apps/mobile/app/**",
      "apps/mobile/app.json",
      "apps/mobile/metro.config.*",
      "apps/mobile/babel.config.*",
      "tests/e2e/maestro/**",
      "**/locales/**"
    ],
    "auto_skip_paths": [
      "**/*.test.ts", "**/*.test.tsx", "**/*.test.js", "**/*.test.jsx",
      "**/*.spec.ts", "**/*.spec.tsx",
      "tests/api/**", "tests/mobile/**",
      "**/*.md", "docs/**",
      "scripts/**", ".claude/**", "CLAUDE.md", ".github/**",
      "apps/api/**", "packages/api/**"
    ],
    "content_pattern_check": {
      "pattern": "testID",
      "applies_to": ["**/*.tsx", "**/*.jsx"]
    }
  },
  "ci_path_filters": {
    "api_test": ["apps/api/**", "packages/**", "package.json", "pnpm-lock.yaml", "biome.json"],
    "mobile_test": ["apps/mobile/**", "packages/**", "package.json", "pnpm-lock.yaml", "biome.json"],
    "e2e_android": ["apps/mobile/**", "tests/e2e/**", "packages/**", ".github/workflows/pr-e2e-android.yml"],
    "lint": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "biome.json"],
    "hooks_test": [".claude/hooks/**", "scripts/**", "tests/hooks/**"]
  },
  "test_coverage_gate": {
    "test_required_paths": [
      "apps/api/src/**/*.ts",
      "apps/mobile/src/**/*.ts",
      "apps/mobile/src/**/*.tsx",
      "packages/**/src/**/*.ts",
      "packages/**/src/**/*.tsx",
      "scripts/gate/*.sh",
      "scripts/lib/*.sh",
      "scripts/skills/*.sh",
      ".claude/hooks/*.sh"
    ],
    "test_path_mapping": [
      {
        "source": "apps/api/src/(.*)\\.ts$",
        "test": "tests/api/$1.test.ts"
      },
      {
        "source": "apps/mobile/src/(.*)\\.tsx$",
        "test": "tests/mobile/$1.test.tsx"
      },
      {
        "source": "apps/mobile/src/(.*)\\.ts$",
        "test": "tests/mobile/$1.test.ts"
      },
      {
        "source": "packages/(.*)/src/(.*)\\.tsx$",
        "test": "packages/$1/tests/$2.test.tsx"
      },
      {
        "source": "packages/(.*)/src/(.*)\\.ts$",
        "test": "packages/$1/tests/$2.test.ts"
      },
      {
        "source": "scripts/gate/(.*)\\.sh$",
        "test": "tests/scripts/gate/$1.bats"
      },
      {
        "source": "scripts/lib/(.*)\\.sh$",
        "test": "tests/scripts/lib/$1.bats"
      },
      {
        "source": "scripts/skills/(.*)\\.sh$",
        "test": "tests/scripts/skills/$1.bats"
      },
      {
        "source": "\\.claude/hooks/(.*)\\.sh$",
        "test": "tests/hooks/$1.bats"
      }
    ],
    "exempt_paths": [
      "**/*.d.ts",
      "**/index.ts",
      "**/types.ts",
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.spec.ts",
      "**/*.spec.tsx",
      "**/*.bats",
      "**/*.config.ts",
      "**/*.config.tsx",
      "**/*.config.js",
      "**/*.config.mjs",
      "**/migrations/**"
    ]
  }
}

{
  "name": "tech-clip",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:mobile": "turbo run dev --filter=@tech-clip/mobile",
    "dev:api": "turbo run dev --filter=@tech-clip/api",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e:ios": "bash scripts/maestro-local.sh ios",
    "test:e2e:android": "bash scripts/maestro-local.sh android",
    "lint": "./scripts/run-biome-check.sh",
    "lint:fix": "./scripts/run-biome-check.sh --write",
    "deploy:staging": "turbo run deploy:staging --filter=@tech-clip/api",
    "deploy:production": "turbo run deploy:production --filter=@tech-clip/api",
    "verify:uncached": "./scripts/verify-uncached.sh",
    "typecheck:uncached": "./scripts/verify-uncached.sh typecheck",
    "test:uncached": "./scripts/verify-uncached.sh test",
    "prepare": "husky",
    "polling-watcher": "bash scripts/polling-watcher.sh"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11",
      "esbuild": ">=0.25.0",
      "brace-expansion": ">=5.0.5",
      "@tootallnate/once": ">=3.0.1",
      "markdown-it": ">=12.3.2",
      "@xmldom/xmldom": ">=0.8.12",
      "lodash": ">=4.18.0",
      "defu": "6.1.6",
      "vite": "8.0.7",
      "minimatch": "^9.0.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.1",
    "husky": "^9.1.7",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  }
}
